{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "*.js",
      "use": "@vercel/static"
    },
    {
      "src": "*.css",
      "use": "@vercel/static"
    },
    {
      "src": "*.json",
      "use": "@vercel/static"
    },
    {
      "src": "icons/*",
      "use": "@vercel/static"
    },
    {
      "src": "consumer/**",
      "use": "@vercel/static"
    },
    {
      "src": "rem/**",
      "use": "@vercel/static"
    },
    {
      "src": "dd/**",
      "use": "@vercel/static"
    },
    {
      "src": "docket/**",
      "use": "@vercel/static"
    },
    {
      "src": "power_map/**",
      "use": "@vercel/static"
    },
    {
      "src": "prt-oil/**",
      "use": "@vercel/static"
    },
    {
      "src": "si-works/**",
      "use": "@vercel/static"
    },
    {
      "src": "stock/**",
      "use": "@vercel/static"
    },
    {
      "src": "Upkeeping/**",
      "use": "@vercel/static"
    },
    {
      "src": "dtr/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
